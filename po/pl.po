msgid "Paste the JSON file's \"raw\" link (e.g. from a GitHub repository)."
msgstr "Wklej link „raw” do pliku JSON (np. z repozytorium GitHub)."

#: casca/window.py:2280
msgid "Fetch"
msgstr "Pobierz"

#: casca/window.py:2292
msgid "Enter a URL."
msgstr "Podaj adres URL."

#: casca/window.py:2294
msgid "Fetching file…"
msgstr "Pobieranie pliku…"

#: casca/window.py:2301
#, python-format
msgid "Error downloading: %(error)s"
msgstr "Błąd pobierania: %(error)s"

#: casca/window.py:2309
#, python-format
msgid "Error importing: %(error)s"
msgstr "Błąd importowania: %(error)s"

#: casca/window.py:2312
msgid "No app found in the file."
msgstr "Nie znaleziono żadnej aplikacji w pliku."

#: casca/window.py:2320
msgid "Nothing selected to import."
msgstr "Nie zaznaczono niczego do zaimportowania."

#: casca/window.py:2328
#, python-format
msgid "%(n)d app imported."
msgid_plural "%(n)d apps imported."
msgstr[0] "Zaimportowano %(n)d aplikację."
msgstr[1] "Zaimportowano %(n)d aplikacje."
msgstr[2] "Zaimportowano %(n)d aplikacji."

#: casca/window.py:2334
#, python-format
msgid "• %(name)s: %(reason)s"
msgstr "• %(name)s: %(reason)s"

#: casca/window.py:2338
#, python-format
msgid "%(created)d imported, %(failed)d with errors"
msgstr "Zaimportowano: %(created)d, z błędami: %(failed)d"

#: casca/window.py:2340
#, python-format
msgid ""
"Review and adjust manually via the \"Create\" button:\n"
"\n"
"%(lines)s"
msgstr ""
"Sprawdź i dostosuj ręcznie za pomocą przycisku „Utwórz”:\n"
"\n"
"%(lines)s"

#: casca/window.py:2342
msgid "Got it"
msgstr "Rozumiem"

#: casca/window.py:2356
msgid "No web apps yet"
msgstr "Brak aplikacji internetowych"

#: casca/window.py:2357
msgid ""
"Tap “Create” to make your first app, or open the Store for ready-made sites."
msgstr ""
"Dotknij „Utwórz”, aby stworzyć pierwszą aplikację, albo otwórz Sklep, aby "
"wybrać gotowe strony."

#: casca/window.py:2366
msgid "My web apps"
msgstr "Moje aplikacje internetowe"

#: casca/window.py:2388
msgid "Installed packages"
msgstr "Zainstalowane pakiety"

#: casca/window.py:2409
#, python-format
msgid "Delete “%(name)s”?"
msgstr "Usunąć „%(name)s”?"

#: casca/window.py:2410
msgid ""
"The shortcut will be removed from the applications menu and the desktop, if "
"it exists."
msgstr ""
"Skrót zostanie usunięty z menu aplikacji i z pulpitu, jeśli tam istnieje."

#: casca/window.py:2413 casca/window.py:2436
msgid "Delete"
msgstr "Usuń"

#: casca/window.py:2427
#, python-format
msgid "Delete package “%(name)s”?"
msgstr "Usunąć pakiet „%(name)s”?"

#: casca/window.py:2429
#, python-format
msgid "Removes the shortcut and the %(n)d app inside it (%(names)s)."
msgid_plural "Removes the shortcut and the %(n)d apps inside it (%(names)s)."
msgstr[0] "Usuwa skrót i %(n)d aplikację znajdującą się w nim (%(names)s)."
msgstr[1] "Usuwa skrót i %(n)d aplikacje znajdujące się w nim (%(names)s)."
msgstr[2] "Usuwa skrót i %(n)d aplikacji znajdujących się w nim (%(names)s)."

