msgstr "Maakt van elke website een GNOME-app."

#: casca/window.py:1313
msgid "No app created yet to export."
msgstr "Er is nog geen app aangemaakt om te exporteren."

#: casca/window.py:1337
#, python-format
msgid "Error exporting: %(error)s"
msgstr "Fout bij exporteren: %(error)s"

#: casca/window.py:1340
#, python-format
msgid "%(count)d app exported to %(name)s."
msgid_plural "%(count)d apps exported to %(name)s."
msgstr[0] "%(count)d app geëxporteerd naar %(name)s."
msgstr[1] "%(count)d apps geëxporteerd naar %(name)s."

#: casca/window.py:1346
msgid "Import from where?"
msgstr "Vanaf waar importeren?"

#: casca/window.py:1347
msgid "Choose a local .json file or a URL (e.g. a GitHub \"raw\" link)."
msgstr ""
"Kies een lokaal .json-bestand of een URL (bijv. een \"raw\"-link van GitHub)."

#: casca/window.py:1349 casca/window.py:1395 casca/window.py:1528
#: casca/window.py:1551
msgid "Cancel"
msgstr "Annuleren"

#: casca/window.py:1350
msgid "From a URL"
msgstr "Van een URL"

#: casca/window.py:1351
msgid "Local file"
msgstr "Lokaal bestand"

#: casca/window.py:1384
#, python-format
msgid "Error reading the file: %(error)s"
msgstr "Fout bij lezen van het bestand: %(error)s"

#: casca/window.py:1390
msgid "Import from a URL"
msgstr "Importeren vanaf een URL"

#: casca/window.py:1391
msgid "Paste the JSON file's \"raw\" link (e.g. from a GitHub repository)."
msgstr ""
"Plak de \"raw\"-link van het JSON-bestand (bijv. van een GitHub-repository)."

#: casca/window.py:1396
msgid "Fetch"
msgstr "Ophalen"

#: casca/window.py:1408
msgid "Enter a URL."
msgstr "Voer een URL in."

#: casca/window.py:1410
msgid "Fetching file…"
msgstr "Bestand ophalen…"

#: casca/window.py:1417
#, python-format
msgid "Error downloading: %(error)s"
msgstr "Fout bij downloaden: %(error)s"

#: casca/window.py:1425
#, python-format
msgid "Error importing: %(error)s"
msgstr "Fout bij importeren: %(error)s"

#: casca/window.py:1428
msgid "No app found in the file."
msgstr "Geen app gevonden in het bestand."

#: casca/window.py:1436
msgid "Nothing selected to import."
msgstr "Niets geselecteerd om te importeren."

#: casca/window.py:1444
#, python-format
msgid "%(n)d app imported."
msgid_plural "%(n)d apps imported."
msgstr[0] "%(n)d app geïmporteerd."
msgstr[1] "%(n)d apps geïmporteerd."

#: casca/window.py:1450
#, python-format
msgid "• %(name)s: %(reason)s"
msgstr "• %(name)s: %(reason)s"

#: casca/window.py:1454
#, python-format
msgid "%(created)d imported, %(failed)d with errors"
msgstr "%(created)d geïmporteerd, %(failed)d met fouten"

#: casca/window.py:1456
#, python-format
msgid ""
"Review and adjust manually via the \"Create\" button:\n"
"\n"
"%(lines)s"
msgstr ""
"Bekijk en pas dit handmatig aan via de knop \"Aanmaken\":\n"
"\n"
"%(lines)s"

#: casca/window.py:1458
msgid "Got it"
msgstr "Begrepen"

#: casca/window.py:1472
msgid "No web apps yet"
msgstr "Nog geen webapps"

#: casca/window.py:1473
msgid ""
"Tap “Create” to make your first app, or open the Store for ready-made sites."
msgstr ""
"Tik op “Aanmaken” om je eerste app te maken, of open de Winkel voor kant-en-"
"klare sites."

#: casca/window.py:1482
msgid "My web apps"
msgstr "Mijn webapps"

#: casca/window.py:1504
msgid "Installed packages"
msgstr "Geïnstalleerde pakketten"

#: casca/window.py:1525
#, python-format
msgid "Delete “%(name)s”?"
msgstr "“%(name)s” verwijderen?"

#: casca/window.py:1526
msgid ""
"The shortcut will be removed from the applications menu and the desktop, if "
"it exists."
msgstr ""
"De snelkoppeling wordt verwijderd uit het toepassingenmenu en van het "
"bureaublad, indien aanwezig."

#: casca/window.py:1529 casca/window.py:1552
msgid "Delete"
msgstr "Verwijderen"

#: casca/window.py:1543
#, python-format
msgid "Delete package “%(name)s”?"
msgstr "Pakket “%(name)s” verwijderen?"

#: casca/window.py:1545
#, python-format
msgid "Removes the shortcut and the %(n)d app inside it (%(names)s)."
msgid_plural "Removes the shortcut and the %(n)d apps inside it (%(names)s)."
msgstr[0] "Verwijdert de snelkoppeling en de %(n)d app erin (%(names)s)."
msgstr[1] "Verwijdert de snelkoppeling en de %(n)d apps erin (%(names)s)."
