#~ msgid ""
#~ "Casca now checks for new releases in the background (once a day at most) "
#~ "and lets you know with a system notification — no action needed for "
#~ "Flatpak/Snap installs, which already update themselves."
#~ msgstr ""
#~ "Casca kini memeriksa rilis baru di latar belakang (paling banyak sekali "
#~ "sehari) dan memberi tahu Anda lewat notifikasi sistem — tidak perlu "
#~ "tindakan apa pun untuk instalasi Flatpak/Snap, yang sudah memperbarui "
#~ "dirinya sendiri."

#~ msgid ""
#~ "The About dialog now shows the license, a link to the source code, "
#~ "whether you're on a release/beta/alpha build, and a proper “What's New” "
#~ "page with each version's changelog."
#~ msgstr ""
#~ "Dialog Tentang kini menampilkan lisensi, tautan ke kode sumber, apakah "
#~ "Anda menggunakan build rilis/beta/alfa, dan halaman “Yang Baru” dengan "
#~ "catatan perubahan tiap versi."

#~ msgid "Type"
#~ msgstr "Jenis"

#~ msgid "Nothing here yet"
#~ msgstr "Belum ada apa-apa di sini"

#~ msgid "Check the local catalog or your internet connection."
#~ msgstr "Periksa katalog lokal atau koneksi internet Anda."

#~ msgid ""
#~ "Casca now speaks 20 languages, picked automatically from the system "
#~ "locale: English, Portuguese (Brazil), Spanish, French, Italian, German, "
#~ "Russian, Ukrainian, Polish, Dutch, Turkish, Simplified Chinese, Japanese, "
#~ "Korean, Vietnamese, Indonesian, Hindi, Arabic, Bengali and Thai."
#~ msgstr ""
#~ "Casca kini mendukung 20 bahasa, dipilih otomatis berdasarkan bahasa "
#~ "sistem: Inggris, Portugis (Brasil), Spanyol, Prancis, Italia, Jerman, "
#~ "Rusia, Ukraina, Polandia, Belanda, Turki, Tionghoa Sederhana, Jepang, "
#~ "Korea, Vietnam, Indonesia, Hindi, Arab, Bengali, dan Thailand."

#~ msgid ""
#~ "The creation screen's browser, mobile mode, resolution and icon sections "
#~ "now have an inline help button — hover for a quick tip, click to jump "
#~ "straight to that topic in a redesigned, example-filled manual."
#~ msgstr ""
#~ "Bagian browser, mode seluler, resolusi, dan ikon di layar pembuatan kini "
#~ "memiliki tombol bantuan bawaan — arahkan kursor untuk tip singkat, klik "
#~ "untuk langsung menuju topik itu di manual yang didesain ulang dan penuh "
#~ "contoh."
