#: casca/window.py:2280
msgid "Fetch"
msgstr "আনুন"

#: casca/window.py:2292
msgid "Enter a URL."
msgstr "একটি URL লিখুন।"

#: casca/window.py:2294
msgid "Fetching file…"
msgstr "ফাইল আনা হচ্ছে…"

#: casca/window.py:2301
#, python-format
msgid "Error downloading: %(error)s"
msgstr "ডাউনলোড করতে ত্রুটি: %(error)s"

#: casca/window.py:2309
#, python-format
msgid "Error importing: %(error)s"
msgstr "আমদানি করতে ত্রুটি: %(error)s"

#: casca/window.py:2312
msgid "No app found in the file."
msgstr "ফাইলে কোনো অ্যাপ পাওয়া যায়নি।"

