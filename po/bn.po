#: casca/window.py:2328
#, python-format
msgid "%(n)d app imported."
msgid_plural "%(n)d apps imported."
msgstr[0] "%(n)d টি অ্যাপ আমদানি করা হয়েছে।"
msgstr[1] "%(n)d টি অ্যাপ আমদানি করা হয়েছে।"

#: casca/window.py:2334
#, python-format
msgid "• %(name)s: %(reason)s"
msgstr "• %(name)s: %(reason)s"

#: casca/window.py:2338
#, python-format
msgid "%(created)d imported, %(failed)d with errors"
msgstr "%(created)d টি আমদানি করা হয়েছে, %(failed)d টিতে ত্রুটি হয়েছে"

#: casca/window.py:2340
#, python-format
msgid ""
"Review and adjust manually via the \"Create\" button:\n"
"\n"
"%(lines)s"
msgstr ""
"\"তৈরি করুন\" বোতামের মাধ্যমে ম্যানুয়ালি পর্যালোচনা ও সামঞ্জস্য করুন:\n"
"\n"
"%(lines)s"

#: casca/window.py:2342
msgid "Got it"
msgstr "বুঝেছি"

#: casca/window.py:2356
msgid "No web apps yet"
msgstr "এখনও কোনো ওয়েব অ্যাপ নেই"

#: casca/window.py:2357
msgid ""
"Tap “Create” to make your first app, or open the Store for ready-made sites."
msgstr ""
"আপনার প্রথম অ্যাপ তৈরি করতে “তৈরি করুন”-এ ট্যাপ করুন, অথবা তৈরি-করা সাইটের জন্য "
"স্টোর খুলুন।"

#: casca/window.py:2366
msgid "My web apps"
msgstr "আমার ওয়েব অ্যাপ"

#: casca/window.py:2388
msgid "Installed packages"
msgstr "ইনস্টল করা প্যাকেজ"

#: casca/window.py:2409
#, python-format
msgid "Delete “%(name)s”?"
msgstr "“%(name)s” মুছবেন?"

#: casca/window.py:2410
msgid ""
"The shortcut will be removed from the applications menu and the desktop, if "
"it exists."
msgstr "শর্টকাটটি অ্যাপ্লিকেশন মেনু এবং ডেস্কটপ থেকে সরিয়ে ফেলা হবে, যদি তা থাকে।"

#: casca/window.py:2413 casca/window.py:2436
msgid "Delete"
msgstr "মুছুন"

#: casca/window.py:2427
#, python-format
msgid "Delete package “%(name)s”?"
msgstr "প্যাকেজ “%(name)s” মুছবেন?"

#: casca/window.py:2429
#, python-format
msgid "Removes the shortcut and the %(n)d app inside it (%(names)s)."
msgid_plural "Removes the shortcut and the %(n)d apps inside it (%(names)s)."
msgstr[0] "শর্টকাট এবং এর ভেতরের %(n)d টি অ্যাপ (%(names)s) মুছে ফেলে।"
msgstr[1] "শর্টকাট এবং এর ভেতরের %(n)d টি অ্যাপ (%(names)s) মুছে ফেলে।"

#~ msgid ""
#~ "Casca now checks for new releases in the background (once a day at most) "
#~ "and lets you know with a system notification — no action needed for "
#~ "Flatpak/Snap installs, which already update themselves."
#~ msgstr ""
#~ "Casca এখন ব্যাকগ্রাউন্ডে নতুন সংস্করণ পরীক্ষা করে (দিনে সর্বোচ্চ একবার) এবং একটি "
#~ "সিস্টেম বিজ্ঞপ্তির মাধ্যমে আপনাকে জানায় — Flatpak/Snap ইনস্টলেশনে কোনো "
#~ "পদক্ষেপের দরকার নেই, কারণ সেগুলো এমনিতেই নিজে থেকে আপডেট হয়।"

#~ msgid ""
#~ "The About dialog now shows the license, a link to the source code, "
#~ "whether you're on a release/beta/alpha build, and a proper “What's New” "
#~ "page with each version's changelog."
#~ msgstr ""
#~ "Casca সম্পর্কে ডায়ালগে এখন লাইসেন্স, সোর্স কোডের লিঙ্ক, আপনি রিলিজ/বিটা/আলফা "
#~ "বিল্ডে আছেন কিনা, এবং প্রতিটি সংস্করণের পরিবর্তন-তালিকাসহ একটি প্রকৃত “নতুন কী "
#~ "আছে” পাতা দেখা যায়।"

#~ msgid "Type"
#~ msgstr "ধরন"

#~ msgid "Nothing here yet"
#~ msgstr "এখানে এখনও কিছু নেই"

#~ msgid "Check the local catalog or your internet connection."
#~ msgstr "স্থানীয় ক্যাটালগ বা আপনার ইন্টারনেট সংযোগ পরীক্ষা করুন।"

