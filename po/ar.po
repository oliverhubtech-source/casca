"راجع واضبط يدويًا عبر زر \"إنشاء\":\n"
"\n"
"%(lines)s"

#: casca/window.py:2342
msgid "Got it"
msgstr "فهمت"

#: casca/window.py:2356
msgid "No web apps yet"
msgstr "لا توجد تطبيقات ويب بعد"

#: casca/window.py:2357
msgid ""
"Tap “Create” to make your first app, or open the Store for ready-made sites."
msgstr "انقر على “إنشاء” لصنع أول تطبيق لك، أو افتح المتجر لمواقع جاهزة."

#: casca/window.py:2366
