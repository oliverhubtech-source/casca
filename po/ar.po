#: casca/window.py:2125 casca/window.py:2199
msgid "Export apps"
msgstr "تصدير التطبيقات"

#: casca/window.py:2156
msgid "Turns any website into a GNOME app."
msgstr "يحوّل أي موقع ويب إلى تطبيق GNOME."

#: casca/window.py:2160
#, python-format
msgid ""
"Version %(latest)s is available — an update notification with a way to "
"update just popped up."
msgstr "الإصدار %(latest)s متاح — ظهر للتو إشعار تحديث يتيح لك التحديث."

#: casca/window.py:2175
msgid ""
"The Store is now the Casca Store, in the style of GNOME Software: a featured "
"apps carousel, colorful category tiles, Editor's Choice, and a page for each "
"app with usage tags, the Bronze/Silver/Gold Casca seal, estimated disk "
"savings, possible PC access and security info."
msgstr "أصبح المتجر الآن متجر Casca بأسلوب برمجيات GNOME: شريط دوّار للتطبيقات المميزة، وفئات ملونة، واختيار المحرر، وصفحة لكل تطبيق تعرض وسوم الاستخدام وختم Casca البرونزي/الفضي/الذهبي والتوفير المقدَّر في القرص وإمكانيات الوصول إلى الحاسوب ومعلومات الأمان."

#: casca/window.py:2181
msgid ""
"A region selector next to the search detects your country automatically and "
"filters marketplaces and news to your region — or choose Global to see "
"everything. All of it translated into the 20 supported languages."
msgstr "مبدّل المنطقة بجوار البحث يكتشف بلدك تلقائيًا ويرشّح الأسواق والأخبار حسب منطقتك — أو اختر «عالمي» لرؤية كل شيء. وكل ذلك مترجم إلى اللغات العشرين المدعومة."

#: casca/window.py:2187
msgid "Source Code"
msgstr "الشيفرة المصدرية"

