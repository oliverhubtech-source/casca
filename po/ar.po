msgstr[0] "يزيل الاختصار دون أي تطبيقات بداخله (%(names)s)."
msgstr[1] "يزيل الاختصار وتطبيقًا واحدًا بداخله (%(names)s)."
msgstr[2] "يزيل الاختصار وتطبيقين بداخله (%(names)s)."
