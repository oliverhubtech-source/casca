#!/usr/bin/make -f

%:
	dh $@

# Pure Python + data, nothing to compile — same "copy the checkout layout as-is"
# approach as the RPM spec and the Flatpak/Snap manifests (see casca.spec,
# snap/snapcraft.yaml): casca/browsers.py and casca/entries.py locate
# run_webview.py/run_package.py as siblings of the installed "casca" package
# directory, so that layout has to be preserved verbatim under /usr/share/casca.
override_dh_auto_configure:

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	set -e; \
	appdir=debian/casca/usr/share/casca; \
	mkdir -p "$$appdir" debian/casca/usr/bin; \
	cp -r casca "$$appdir/casca"; \
	cp run.py run_webview.py run_package.py "$$appdir/"; \
	printf '#!/bin/sh\nexec python3 /usr/share/casca/run.py "$$@"\n' > debian/casca/usr/bin/casca; \
	chmod 755 debian/casca/usr/bin/casca

	install -Dm644 casca/data/io.github.oliverhubtech_source.Casca.desktop \
		debian/casca/usr/share/applications/io.github.oliverhubtech_source.Casca.desktop
	install -Dm644 casca/data/io.github.oliverhubtech_source.Casca.metainfo.xml \
		debian/casca/usr/share/metainfo/io.github.oliverhubtech_source.Casca.metainfo.xml
	install -Dm644 casca/data/icons/io.github.oliverhubtech_source.Casca.png \
		debian/casca/usr/share/icons/hicolor/256x256/apps/io.github.oliverhubtech_source.Casca.png
